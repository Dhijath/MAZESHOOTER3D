   ・アウトラインカラーを単色で出力するだけのシンプルなPS
   ・色は b0 で外部から指定（黒以外にも変更可能）

==============================================================================*/
//=============================================================================
// アウトライン用 ピクセルシェーダー (shader_pixel_outline.hlsl)
// - b0 : アウトライン色（通常は黒 {0,0,0,1}）
//=============================================================================

cbuffer OUTLINE_COLOR : register(b0)
{
    float4 outlineColor; // アウトラインの色（デフォルト黒）
}

struct PS_IN
{
    float4 posH : SV_POSITION;
};

float4 main(PS_IN pi) : SV_TARGET
{
    return outlineColor;
}
