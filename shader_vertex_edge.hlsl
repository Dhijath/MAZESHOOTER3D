/*==============================================================================

   エッジ検出用頂点シェーダー [shader_vertex_edge.hlsl]
                                                         Author : 51106
                                                         Date   : 2026/03/11
--------------------------------------------------------------------------------
   - 頂点バッファなしでフルスクリーン矩形を描画する
   - SV_VertexID から UV とクリップ座標を生成
   - Draw(3, 0) で三角形1枚を描くだけでフルスクリーンになる

==============================================================================*/

struct VS_OUT
{
    float4 posH : SV_POSITION;
    float2 uv   : TEXCOORD0;
};

VS_OUT main(uint vid : SV_VertexID)
{
    VS_OUT vo;

    // 頂点ID 0,1,2 から UV を生成
    float2 uv = float2((vid << 1) & 2, vid & 2);

    // UV を -1~1 のクリップ座標に変換（Y反転）
    vo.posH = float4(uv.x * 2.0f - 1.0f, -(uv.y * 2.0f - 1.0f), 0.0f, 1.0f);
    vo.uv   = uv;

    return vo;
}
